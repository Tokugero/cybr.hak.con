# Credential scrubber — Tier 0 hygiene for AI coding agents (macOS)
#
# Activated by direnv when you cd into this directory. Two layers:
#   1. Unset credential values that may be present in the parent shell's env.
#   2. Redirect default config paths so tools can't fall back to disk.
#
# Together these mean a tool spawned in this shell won't find credentials
# in your environment AND won't find them by reading the usual config
# locations (~/.aws, ~/.kube, ~/.talos, etc.). The tool needs explicit
# reconfiguration to acquire credentials.
#
# This is Tier 0 hygiene. It does NOT prevent code already running with
# elevated access from reading credential files directly (`cat
# ~/.aws/credentials`), and it does NOT disconnect this shell from the
# macOS Keychain. See ../discussion.md and notes.md for what this misses.

log_status "credential scrubber active for this directory"

# ─────────────────────────────────────────────────────────────────────
# Layer 1 — unset credential values that may be in the parent shell
# ─────────────────────────────────────────────────────────────────────

# ── Cloud: AWS ──
unset AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_SESSION_TOKEN
unset AWS_PROFILE AWS_DEFAULT_PROFILE
unset AWS_REGION AWS_DEFAULT_REGION

# ── Cloud: GCP ──
unset GOOGLE_APPLICATION_CREDENTIALS
unset GCLOUD_PROJECT GOOGLE_CLOUD_PROJECT
while IFS='=' read -r var _; do
  case "$var" in CLOUDSDK_*) unset "$var" ;; esac
done < <(env)

# ── Cloud: Azure ──
while IFS='=' read -r var _; do
  case "$var" in AZURE_*|ARM_*) unset "$var" ;; esac
done < <(env)

# ── Infrastructure ──
unset TERRAFORM_TOKEN
while IFS='=' read -r var _; do
  case "$var" in TF_TOKEN_*|TF_VAR_*) unset "$var" ;; esac
done < <(env)
unset KUBE_TOKEN KUBE_CONTEXT
unset KUBERNETES_SERVICE_HOST KUBERNETES_SERVICE_PORT
unset PULUMI_ACCESS_TOKEN PULUMI_CONFIG_PASSPHRASE

# ── Source control ──
unset GITHUB_TOKEN GH_TOKEN
unset GITLAB_TOKEN GITLAB_PAT
unset BITBUCKET_TOKEN

# ── LLM API keys ──
unset ANTHROPIC_API_KEY
unset OPENAI_API_KEY
unset GOOGLE_API_KEY GEMINI_API_KEY
unset MISTRAL_API_KEY COHERE_API_KEY GROQ_API_KEY
unset TOGETHER_API_KEY REPLICATE_API_TOKEN

# ── Package registries ──
unset NPM_TOKEN
unset CARGO_REGISTRY_TOKEN
unset PYPI_TOKEN
unset NUGET_API_KEY

# ── Secrets managers ──
unset VAULT_TOKEN VAULT_ADDR VAULT_NAMESPACE

# ── Container/registry tooling ──
unset DOCKER_HOST DOCKER_TLS_VERIFY DOCKER_CERT_PATH
unset CONTAINER_HOST

# ── Hosting / CDN ──
unset NETLIFY_AUTH_TOKEN
unset VERCEL_TOKEN
unset CF_API_TOKEN CF_API_KEY

# ── Misc API ──
unset SLACK_TOKEN SLACK_WEBHOOK_URL
unset SENDGRID_API_KEY
unset DATADOG_API_KEY

# ── SSH agent ──
# Aggressive: disconnects this shell from loaded keys. Right for an
# untrusted workload, wrong for everyday dev. Choose deliberately.
unset SSH_AUTH_SOCK

# ─────────────────────────────────────────────────────────────────────
# Layer 2 — redirect default config paths so tools can't fall back
# ─────────────────────────────────────────────────────────────────────
# Without this layer, kubectl reads ~/.kube/config, talosctl reads
# ~/.talos/config, aws CLI reads ~/.aws/credentials, etc., even when
# the corresponding env vars are unset. Layer 2 points these env vars
# at empty locations.

# File-based redirects (/dev/null is readable, zero bytes; tools treat
# as "no config" and proceed)
export AWS_CONFIG_FILE=/dev/null
export AWS_SHARED_CREDENTIALS_FILE=/dev/null
export KUBECONFIG=/dev/null
export TALOSCONFIG=/dev/null
export TF_CLI_CONFIG_FILE=/dev/null
export SOPS_AGE_KEY_FILE=/dev/null
export NPM_CONFIG_USERCONFIG=/dev/null
export GIT_CONFIG_GLOBAL=/dev/null

# Directory-based redirects (one shared empty parent, with named subdirs
# that some tools insist on existing)
SCRUB_EMPTY="$(mktemp -d "${TMPDIR:-/tmp}/cred-scrub-empty-XXXXXX")"
mkdir -p "$SCRUB_EMPTY"/{gcloud,azure,docker,cargo,pulumi}
export CLOUDSDK_CONFIG="$SCRUB_EMPTY/gcloud"
export AZURE_CONFIG_DIR="$SCRUB_EMPTY/azure"
export DOCKER_CONFIG="$SCRUB_EMPTY/docker"
export CARGO_HOME="$SCRUB_EMPTY/cargo"
export PULUMI_HOME="$SCRUB_EMPTY/pulumi"

# ── Load project-specific env (after both layers) ──
dotenv_if_exists .env
