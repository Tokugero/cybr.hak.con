# Copy to .env and fill in values from your VPN provider.
# .env is gitignored at the repo root; never commit it.
#
# The example below is for Mullvad with WireGuard. gluetun supports
# many other providers; see https://github.com/qdm12/gluetun/wiki
# for the per-provider env-var requirements.
#
# WITHOUT THESE VALUES, gluetun fails to establish a tunnel. That is
# the fail-closed scenario the workshop demonstrates by default — the
# worker has no usable network, which is exactly what we want to show.
#
# WITH VALUES, the worker's egress goes through your VPN provider,
# and the egress probe will report a different exit IP than your host.

VPN_SERVICE_PROVIDER=mullvad
VPN_TYPE=wireguard

# Mullvad-specific: the private key and address from your account.
# Get these from https://mullvad.net/en/account/wireguard-config
# (download a config; copy PrivateKey and Address out of it).
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=

# Pick a country for the exit. Mullvad has many; "Sweden" is a default.
SERVER_COUNTRIES=Sweden
