# sample.envrc — example perimeter for educational purposes
#
# This is what direnv loads when you `direnv allow` in this directory.
# It demonstrates the two halves of the Tier 0 pattern:
#   1. Scrubbing broad credentials (a small subset; cred-scrub does the
#      full version).
#   2. Injecting narrow, scoped credentials for the work in this directory.
#
# Read each line. Don't `direnv allow` an .envrc you haven't read.

log_status "perimeter active for $(basename "$PWD")"

# ─────────────────────────────────────────────────────────
# Sentinels — so the fingerprint script can see we loaded
# ─────────────────────────────────────────────────────────
export PERIMETER_ACTIVE=yes
export PERIMETER_NAME=sample

# ─────────────────────────────────────────────────────────
# Scrub a small set of broad credentials
# ─────────────────────────────────────────────────────────
# Illustrative subset only. For comprehensive scrubbing across all the
# credential categories, see ../cred-scrub/linux/solution.envrc.
unset AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_SESSION_TOKEN
unset GITHUB_TOKEN GH_TOKEN
unset ANTHROPIC_API_KEY OPENAI_API_KEY

# ─────────────────────────────────────────────────────────
# Inject narrow, scoped credentials for this perimeter
# ─────────────────────────────────────────────────────────
# These values are placeholders. In real use:
#   AWS_PROFILE=engagement-test     would name a profile in ~/.aws/config
#                                   that AssumeRoles into a read-only role
#                                   for this work only.
#   KUBECONFIG=$PWD/.kubeconfig     would point at a kubeconfig with a
#                                   narrow service account, not your
#                                   cluster-admin context.
#
# Patterns for actually fetching scoped credentials (aws-vault, Vault,
# 1Password CLI, sops) are described in ../patterns.md.

export AWS_PROFILE=engagement-test
export AWS_REGION=us-east-2
export KUBECONFIG="$PWD/.kubeconfig"

# ─────────────────────────────────────────────────────────
# Source machine-specific secrets (gitignored)
# ─────────────────────────────────────────────────────────
# .envrc.local holds machine-specific values that shouldn't be committed.
# See sample.envrc.local.example for the shape.
dotenv_if_exists .envrc.local
